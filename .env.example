# Database connection (use NUXT_ prefix to prevent build-time exposure)
NUXT_DATABASE_URL=postgresql://postgres:dbname_2026@localhost:5432/linktab

# Site configuration
NUXT_SITE_TOKEN=synlink@111
NUXT_SITE_USER=root
NUXT_REDIRECT_STATUS_CODE=301
NUXT_REDIRECT_WITH_QUERY=false
NUXT_HOME_URL=
NUXT_CASE_SENSITIVE=false
NUXT_NOT_FOUND_REDIRECT=
NUXT_PUBLIC_SLUG_DEFAULT_LENGTH=4
NUXT_PUBLIC_PREVIEW_MODE=

# Encryption key for API keys (32+ characters recommended)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change-this-to-a-secure-random-key-in-production
